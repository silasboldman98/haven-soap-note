# Haven SOAP Note Generator — Environment Variables
# Copy this file to .env and fill in real values before deploying

# OpenAI API Key (for GPT-4o SOAP note generation)
OPENAI_API_KEY=sk-...

# Twilio credentials (same account used for the voice agent)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# Default on-call nurse number (receives SOAP note SMS after each call)
# In production, replace with a schedule lookup system
DEFAULT_NURSE_NUMBER=+1xxxxxxxxxx

# Optional: Vapi webhook secret for request verification
VAPI_WEBHOOK_SECRET=

# Server port (Railway/Render set this automatically)
PORT=5000
